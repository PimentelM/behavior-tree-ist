{
  "name": "@behavior-tree-ist/studio-server",
  "version": "0.1.0",
  "description": "Behavior Tree Studio server",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^4.29.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
