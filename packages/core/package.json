{
  "name": "@bt-studio/core",
  "version": "0.1.2",
  "description": "A behaviour tree library for TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./tsx": {
      "import": {
        "types": "./dist/tsx.d.mts",
        "default": "./dist/tsx.mjs"
      },
      "require": {
        "types": "./dist/tsx.d.ts",
        "default": "./dist/tsx.js"
      }
    },
    "./inspector": {
      "import": {
        "types": "./dist/inspector.d.mts",
        "default": "./dist/inspector.mjs"
      },
      "require": {
        "types": "./dist/inspector.d.ts",
        "default": "./dist/inspector.js"
      }
    },
    "./demos": {
      "import": {
        "types": "./dist/demos.d.mts",
        "default": "./dist/demos.mjs"
      },
      "require": {
        "types": "./dist/demos.d.ts",
        "default": "./dist/demos.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn build && yarn typecheck && yarn lint && yarn test"
  },
  "keywords": [
    "behaviour-tree",
    "behavior-tree",
    "ai",
    "game-ai",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PimentelM/behavior-tree-ist.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/PimentelM/behavior-tree-ist/tree/main/packages/core",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
