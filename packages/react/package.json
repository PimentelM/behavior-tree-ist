{
  "name": "@bt-studio/react",
  "version": "0.1.0",
  "description": "React debugger component for bt-studio",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@bt-studio/core": "^0.1.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1",
    "@xyflow/react": "^12"
  },
  "devDependencies": {
    "@bt-studio/core": "workspace:*",
    "@testing-library/dom": "^10",
    "@testing-library/react": "^16",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9.0.0",
    "jsdom": "^25",
    "react": "^18",
    "react-dom": "^18",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "behaviour-tree",
    "behavior-tree",
    "react",
    "debugger",
    "inspector"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PimentelM/behavior-tree-ist.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/PimentelM/behavior-tree-ist/tree/main/packages/react",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
