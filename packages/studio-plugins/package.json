{
    "name": "@bt-studio/studio-plugins",
    "version": "0.1.1",
    "description": "Plugin package for BT Studio — ships ReplPlugin (NaCl E2E encrypted JavaScript eval) and other first-party plugins",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "behaviour-tree",
        "behavior-tree",
        "repl",
        "studio"
    ],
    "author": "",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PimentelM/behavior-tree-ist.git",
        "directory": "packages/studio-plugins"
    },
    "homepage": "https://github.com/PimentelM/behavior-tree-ist/tree/main/packages/studio-plugins",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@noble/hashes": "^1.6.1",
        "tweetnacl": "^1.0.3"
    },
    "peerDependencies": {
        "@bt-studio/core": "^0.1.0"
    },
    "devDependencies": {
        "@bt-studio/core": "workspace:*",
        "eslint": "^9.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
