{
    "name": "@bt-studio/studio-transport",
    "version": "0.1.1",
    "description": "Studio transport protocol and abstraction for bt-studio",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        },
        "./node": {
            "import": {
                "types": "./dist/node.d.mts",
                "default": "./dist/node.mjs"
            },
            "require": {
                "types": "./dist/node.d.ts",
                "default": "./dist/node.js"
            }
        },
        "./web": {
            "import": {
                "types": "./dist/web.d.mts",
                "default": "./dist/web.mjs"
            },
            "require": {
                "types": "./dist/web.d.ts",
                "default": "./dist/web.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "@bt-studio/core": "^0.1.0",
        "ws": "^8.0.0"
    },
    "peerDependenciesMeta": {
        "ws": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/ws": "^8.18.1",
        "eslint": "^9.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "author": "",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PimentelM/behavior-tree-ist.git",
        "directory": "packages/studio-transport"
    },
    "homepage": "https://github.com/PimentelM/behavior-tree-ist/tree/main/packages/studio-transport",
    "publishConfig": {
        "access": "public"
    }
}
